---
import BaseHead from "../../components/BaseHead.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { getCollection } from "astro:content";
import FormattedDate from "../../components/FormattedDate.astro";
import { Image } from "astro:assets";
import HeroBackground from "../../components/HeroBackground.astro";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title="Blog | DGarbs51" description="Articles about development, leadership, Laravel, and lessons learned building software." />
  </head>
  <body
    class="relative flex min-h-screen flex-col bg-white text-zinc-900 dark:bg-zinc-950 dark:text-zinc-100"
  >
    <HeroBackground />
    <Header />
    <main
      class="relative z-10 mx-auto max-w-5xl grow px-4 py-12 sm:px-6 lg:px-8"
    >
      <h1
        class="font-heading mb-8 text-4xl font-bold tracking-tight text-zinc-900 dark:text-white"
      >
        Blog Posts
      </h1>
      <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
        {
          posts.map(post => (
            <article>
              <a
                href={`/blog/${post.id}/`}
                class="group shadow-card hover:shadow-card-hover block overflow-hidden rounded-2xl border border-zinc-200 bg-white transition-[box-shadow,transform] duration-200 ease-out hover:-translate-y-1 dark:border-zinc-800 dark:bg-zinc-900"
              >
                {post.data.heroImage && (
                  <Image
                    width={720}
                    height={360}
                    src={post.data.heroImage}
                    alt={`Hero image for ${post.data.title}`}
                    class="h-48 w-full object-cover"
                  />
                )}
                <div class="bg-white p-5 dark:bg-zinc-900">
                  <h2 class="font-heading group-hover:text-accent-600 dark:group-hover:text-accent-400 text-lg font-semibold text-zinc-900 transition-colors dark:text-white">
                    {post.data.title}
                  </h2>
                  <p class="mt-1 text-sm text-zinc-500 dark:text-zinc-400">
                    <FormattedDate date={post.data.pubDate} />
                  </p>
                  {post.data.description && (
                    <p class="mt-2 line-clamp-2 text-sm text-zinc-600 dark:text-zinc-400">
                      {post.data.description}
                    </p>
                  )}
                </div>
              </a>
            </article>
          ))
        }
      </div>
    </main>
    <Footer />
  </body>
</html>
