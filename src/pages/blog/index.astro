---
import BaseHead from "../../components/BaseHead.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../../consts";
import { getCollection } from "astro:content";
import FormattedDate from "../../components/FormattedDate.astro";
import { Image } from "astro:assets";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body class="bg-white text-zinc-900 dark:bg-zinc-950 dark:text-zinc-100">
    <Header />
    <main class="mx-auto max-w-5xl px-4 py-12 sm:px-6 lg:px-8">
      <h1
        class="mb-8 text-4xl font-bold tracking-tight text-zinc-900 dark:text-white"
      >
        Blog
      </h1>
      <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
        {
          posts.map(post => (
            <a
              href={`/blog/${post.id}/`}
              class="group overflow-hidden rounded-2xl border border-zinc-200 shadow-sm transition-all hover:shadow-lg dark:border-zinc-800"
            >
              {post.data.heroImage && (
                <Image
                  width={720}
                  height={360}
                  src={post.data.heroImage}
                  alt=""
                  class="h-48 w-full object-cover"
                />
              )}
              <div class="p-5">
                <h2 class="group-hover:text-accent-600 dark:group-hover:text-accent-400 text-lg font-semibold text-zinc-900 transition-colors dark:text-white">
                  {post.data.title}
                </h2>
                <p class="mt-1 text-sm text-zinc-500 dark:text-zinc-400">
                  <FormattedDate date={post.data.pubDate} />
                </p>
                {post.data.description && (
                  <p class="mt-2 line-clamp-2 text-sm text-zinc-600 dark:text-zinc-400">
                    {post.data.description}
                  </p>
                )}
              </div>
            </a>
          ))
        }
      </div>
    </main>
    <Footer />
  </body>
</html>
