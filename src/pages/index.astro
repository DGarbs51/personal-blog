---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import HeroBackground from "../components/HeroBackground.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body
    class="relative isolate flex min-h-dvh flex-col bg-white text-zinc-900 antialiased dark:bg-zinc-900 dark:text-zinc-100"
  >
    <HeroBackground />
    <Header />
    <main
      class="relative mx-auto max-w-4xl grow px-4 pt-8 pb-6 sm:px-6 sm:pt-16 sm:pb-8 lg:px-8"
    >
      <section class="text-center">
        <h1
          class="font-display text-3xl font-semibold tracking-tight text-balance text-zinc-900 sm:text-5xl md:text-6xl dark:text-zinc-100"
        >
          I Thought the <span class="text-accent-600 dark:text-zinc-100"
            >Hard Part</span
          >
          <br />
          Was the <span class="text-accent-600 dark:text-zinc-100">Code</span>
        </h1>
        <p
          class="mx-auto mt-4 max-w-2xl text-base/7 text-pretty text-zinc-600 sm:mt-6 sm:text-lg/8 md:text-xl/8 dark:text-zinc-400"
        >
          I'm Devon — Solutions Engineer at Laravel, husband, father, and
          someone who learned a few Excel formulas and thought that meant
          software engineering would be easy. A decade later, I've built
          cloud-native platforms in highly regulated environments, discovered an
          entire dimension nobody warned me about, and visited 34 national parks
          somewhere in between.
        </p>
        <p
          class="mx-auto mt-6 max-w-2xl text-lg/7 font-medium text-pretty text-zinc-900 sm:mt-8 sm:text-xl/8 md:text-2xl/9 dark:text-zinc-100"
        >
          This is where I think out loud about that other dimension —
          leadership, Laravel, ADHD, and why <span
            class="text-accent-600 dark:text-zinc-100">shipping</span
          > is so damn hard when
          <span class="text-accent-600 dark:text-zinc-100">starting</span> is your
          favorite part.
        </p>
        <div
          class="mt-6 flex flex-col items-center justify-center gap-3 sm:mt-10 sm:flex-row sm:gap-4"
        >
          <a
            href="/blog"
            class="bg-accent-600 hover:bg-accent-500 dark:bg-accent-400 dark:hover:bg-accent-300 focus-visible:outline-accent-500 w-full rounded-lg px-4 py-2.5 text-base font-semibold text-white shadow-xs transition-colors focus-visible:outline-2 focus-visible:outline-offset-2 sm:w-auto sm:text-sm dark:text-zinc-900"
          >
            Read the Blog
          </a>
          <a
            href="/about"
            class="focus-visible:outline-accent-500 w-full rounded-lg bg-white px-4 py-2.5 text-base font-semibold text-zinc-900 ring-1 ring-zinc-950/10 transition-colors hover:bg-zinc-50 focus-visible:outline-2 focus-visible:outline-offset-2 sm:w-auto sm:text-sm dark:bg-zinc-800 dark:text-zinc-100 dark:ring-white/10 dark:hover:bg-zinc-700"
          >
            More About Devon
          </a>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>
