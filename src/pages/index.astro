---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import HeroBackground from "../components/HeroBackground.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body
    class="relative flex min-h-screen flex-col bg-white text-zinc-900 dark:bg-zinc-900 dark:text-zinc-100"
  >
    <HeroBackground />
    <Header />
    <main
      class="relative mx-auto max-w-4xl grow px-4 pt-8 pb-6 sm:px-6 sm:pt-16 sm:pb-8 lg:px-8"
    >
      <section class="text-center">
        <h1
          class="font-heading text-3xl font-bold tracking-tight text-zinc-900 sm:text-5xl md:text-6xl dark:text-zinc-100"
        >
          I Thought the <span class="text-accent-600 dark:text-accent-400"
            >Hard Part</span
          >
          <br />
          Was the <span class="text-accent-600 dark:text-accent-400">Code</span>
        </h1>
        <p
          class="mx-auto mt-4 max-w-2xl text-base leading-relaxed text-zinc-600 sm:mt-6 sm:text-lg md:text-xl dark:text-zinc-400"
        >
          I'm Devon — Solutions Engineer at Laravel, husband, father, and
          someone who learned a few Excel formulas and thought that meant
          software engineering would be easy. A decade later, I've built
          cloud-native platforms in highly regulated environments, discovered an
          entire dimension nobody warned me about, and visited 34 national parks
          somewhere in between.
        </p>
        <p
          class="mx-auto mt-6 max-w-2xl text-lg leading-snug font-medium text-zinc-900 sm:mt-8 sm:text-xl md:text-2xl dark:text-zinc-100"
        >
          This is where I think out loud about that other dimension —
          leadership, Laravel, ADHD, and why <span
            class="text-accent-600 dark:text-accent-400">shipping</span
          > is so damn hard when
          <span class="text-accent-600 dark:text-accent-400">starting</span> is your
          favorite part.
        </p>
        <div
          class="mt-6 flex flex-col items-center justify-center gap-3 sm:mt-10 sm:flex-row sm:gap-4"
        >
          <a
            href="/blog"
            class="bg-accent-600 hover:bg-accent-500 dark:bg-accent-400 dark:hover:bg-accent-300 w-full rounded-lg px-6 py-3 text-sm font-semibold text-white shadow-xs transition-colors sm:w-auto dark:text-zinc-900"
          >
            Read the Blog
          </a>
          <a
            href="/about"
            class="w-full rounded-lg border border-zinc-300 bg-white px-6 py-3 text-sm font-semibold text-zinc-900 transition-colors hover:bg-zinc-50 sm:w-auto dark:border-zinc-700 dark:bg-zinc-800 dark:text-zinc-100 dark:hover:bg-zinc-700"
          >
            More About Devon
          </a>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>
