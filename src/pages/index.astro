---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body class="bg-white text-zinc-900 dark:bg-zinc-950 dark:text-zinc-100">
    <Header />
    <main class="mx-auto max-w-4xl px-4 py-16 sm:px-6 sm:py-24 lg:px-8">
      <section class="text-center">
        <h1
          class="text-5xl font-bold tracking-tight text-zinc-900 sm:text-6xl dark:text-white"
        >
          Building Software Is Easy.
          <br />
          Building Everything Around It Isn't.
        </h1>
        <p
          class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-zinc-600 sm:text-xl dark:text-zinc-400"
        >
          I'm Devon — a Solutions Engineer at Laravel, a dad, and someone who's
          spent a decade learning that the hardest problems in tech aren't
          technical. I've built cloud-native platforms in highly regulated
          environments, led teams through ambiguity, and visited 34 national
          parks along the way.
        </p>
        <p
          class="mx-auto mt-4 max-w-2xl text-base leading-relaxed text-zinc-500 dark:text-zinc-500"
        >
          This is where I think out loud about leadership, Laravel, ADHD, and
          what it actually looks like to choose finishing over starting.
        </p>
        <div class="mt-10 flex items-center justify-center gap-4">
          <a
            href="/blog"
            class="bg-accent-600 hover:bg-accent-500 rounded-lg px-6 py-3 text-sm font-semibold text-white shadow-sm transition-colors"
          >
            Read the Latest
          </a>
          <a
            href="/about"
            class="rounded-lg border border-zinc-300 px-6 py-3 text-sm font-semibold text-zinc-900 transition-colors hover:bg-zinc-50 dark:border-zinc-700 dark:text-zinc-100 dark:hover:bg-zinc-800"
          >
            Get to Know Me
          </a>
        </div>
      </section>

      <p class="mt-16 text-center text-xs text-zinc-400 dark:text-zinc-600">
        All thoughts and opinions expressed here are my own and do not reflect
        those of my employer.
      </p>
    </main>
    <Footer />
  </body>
</html>
