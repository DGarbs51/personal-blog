---
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import { Image } from "astro:assets";
import HeroBackground from "../components/HeroBackground.astro";

type Props = CollectionEntry<"blog">["data"] & { showBackLink?: boolean };

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  showBackLink = true,
} = Astro.props;
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description} image={heroImage} type="Article" datePublished={pubDate} dateModified={updatedDate} />
  </head>

  <body
    class="relative flex min-h-screen flex-col bg-white text-zinc-900 dark:bg-zinc-900 dark:text-zinc-100"
  >
    <HeroBackground />
    <Header />
    <main
      class="relative z-10 mx-auto max-w-4xl grow px-4 py-8 sm:px-6 lg:px-8"
    >
      {
        showBackLink && (
          <a
            href="/blog"
            class="mb-6 inline-flex items-center gap-1 text-sm font-medium text-zinc-500 transition-colors hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-100"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 20 20"
              fill="currentColor"
              class="size-4"
            >
              <path
                fill-rule="evenodd"
                d="M17 10a.75.75 0 0 1-.75.75H5.612l4.158 3.96a.75.75 0 1 1-1.04 1.08l-5.5-5.25a.75.75 0 0 1 0-1.08l5.5-5.25a.75.75 0 1 1 1.04 1.08L5.612 9.25H16.25A.75.75 0 0 1 17 10Z"
                clip-rule="evenodd"
              />
            </svg>
            Back to Blog Posts
          </a>
        )
      }
      <article>
        {
          heroImage && (
            <div class="mb-8">
              <Image
                width={1020}
                height={510}
                src={heroImage}
                alt={`Hero image for ${title}`}
                loading="eager"
                class="w-full rounded-2xl shadow-lg"
              />
            </div>
          )
        }
        <div class="prose prose-lg prose-indigo dark:prose-invert max-w-none">
          <div
            class="mb-8 border-b border-zinc-200 pb-8 text-center dark:border-zinc-700"
          >
            <div class="mb-2 text-zinc-500 dark:text-zinc-400">
              <FormattedDate date={pubDate} />
              {
                updatedDate && (
                  <div class="italic">
                    Last updated on <FormattedDate date={updatedDate} />
                  </div>
                )
              }
            </div>
            <h1 class="mb-0">{title}</h1>
          </div>
          <slot />
        </div>
      </article>
    </main>
    <Footer />
    <script is:inline>
      (function () {
        if (typeof fathom === "undefined") return;

        // Scroll depth tracking — fire once per threshold
        var scrollFired = {};
        var thresholds = [25, 50, 75, 100];

        window.addEventListener("scroll", function () {
          var scrollTop = window.scrollY || document.documentElement.scrollTop;
          var docHeight = document.documentElement.scrollHeight - window.innerHeight;
          if (docHeight <= 0) return;
          var percent = Math.round((scrollTop / docHeight) * 100);

          for (var i = 0; i < thresholds.length; i++) {
            var t = thresholds[i];
            if (percent >= t && !scrollFired[t]) {
              scrollFired[t] = true;
              fathom.trackEvent("scroll_depth_" + t);
            }
          }
        });

        // Code block copy-to-clipboard tracking
        document.querySelectorAll("pre code").forEach(function (block) {
          block.addEventListener("copy", function () {
            fathom.trackEvent("code_block_copy");
          });
        });

        // Outbound link click tracking
        document.querySelectorAll('a[href^="http"]').forEach(function (link) {
          if (link.hostname === window.location.hostname) return;
          link.addEventListener("click", function () {
            fathom.trackEvent("outbound_click: " + link.hostname);
          });
        });
      })();
    </script>
  </body>
</html>
