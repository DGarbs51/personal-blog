---
import HeaderLink from "./HeaderLink.astro";
import Logo from "./Logo.astro";
import ThemeToggle from "./ThemeToggle.astro";
import { SITE_TITLE } from "../consts";

interface Props {}
---

<header
  class="sticky top-0 z-50 bg-white px-4 shadow-xs dark:border-b dark:border-zinc-700 dark:bg-zinc-800 dark:shadow-none"
>
  <nav class="mx-auto flex max-w-5xl items-center justify-between">
    <h2 class="font-heading m-0 text-base whitespace-nowrap">
      <a
        href="/"
        class="flex items-center gap-2 text-zinc-800 no-underline dark:text-zinc-200"
      >
        <Logo size="small" showText={false} />
      </a>
    </h2>
    <div class="flex items-center gap-1">
      <HeaderLink href="/">Home</HeaderLink>
      <HeaderLink href="/blog">Blog</HeaderLink>
      <HeaderLink href="/about">About</HeaderLink>
    </div>
    <ThemeToggle />
  </nav>
</header>
