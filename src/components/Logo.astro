---
interface Props {
  size?: "small" | "medium" | "large";
  showText?: boolean;
}

const { size = "medium", showText = true } = Astro.props;

const dimensions = {
  small: "28",
  medium: "36",
  large: "48",
};
---

<div class="flex items-center gap-3">
  <img
    src="/logo.svg"
    alt="DGarbs51 Logo"
    width={dimensions[size]}
    height={dimensions[size]}
    class="shrink-0 transition-transform duration-200 ease-in-out hover:scale-105"
  />

  {
    showText && (
      <span class="text-accent-600 dark:text-accent-400 text-[1.1em] font-bold tracking-tight">
        DGarbs51
      </span>
    )
  }
</div>
