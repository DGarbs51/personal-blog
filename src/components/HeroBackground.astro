<!--
  Homepage background — soft gradient mesh blobs + angled panels.
  Full viewport width, sits behind all page content.
-->
<div
  class="pointer-events-none fixed inset-0 overflow-hidden"
  aria-hidden="true"
>
  <!-- Gradient mesh blobs — soft, diffused -->
  <div
    class="bg-accent-400/10 dark:bg-accent-500/10 absolute -top-48 -right-48 h-[700px] w-[700px] rounded-full blur-[140px]"
  >
  </div>
  <div
    class="absolute -bottom-48 -left-48 h-[600px] w-[600px] rounded-full bg-purple-400/8 blur-[120px] dark:bg-purple-500/8"
  >
  </div>
  <div
    class="absolute top-1/3 left-1/4 h-[500px] w-[500px] rounded-full bg-blue-400/6 blur-[120px] dark:bg-blue-500/5"
  >
  </div>

  <!-- Angled geometric panels -->
  <div
    class="from-accent-500/[0.04] dark:from-accent-400/[0.05] absolute -top-1/2 -right-1/4 h-full w-3/4 origin-center rotate-[20deg] bg-gradient-to-br via-transparent to-transparent"
  >
  </div>
  <div
    class="absolute -bottom-1/3 -left-1/4 h-3/4 w-3/4 origin-center -rotate-[15deg] bg-gradient-to-tr from-purple-500/[0.03] via-transparent to-transparent dark:from-purple-400/[0.04]"
  >
  </div>

  <!-- Thin diagonal accent lines -->
  <svg
    class="absolute inset-0 h-full w-full opacity-[0.08] dark:opacity-[0.1]"
    preserveAspectRatio="none"
    viewBox="0 0 1000 800"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
  >
    <line
      x1="0"
      y1="650"
      x2="1000"
      y2="150"
      class="stroke-accent-500 dark:stroke-accent-400"
      stroke-width="1"></line>
    <line
      x1="0"
      y1="700"
      x2="1000"
      y2="200"
      class="stroke-accent-500/50 dark:stroke-accent-400/50"
      stroke-width="0.75"></line>
    <line
      x1="200"
      y1="0"
      x2="1000"
      y2="600"
      class="stroke-purple-500 dark:stroke-purple-400"
      stroke-width="0.75"></line>
  </svg>
</div>
